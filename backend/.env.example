# ============================================================
# FitFlow Pro — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# ============================================================

# --- Ambiente ---
FLASK_ENV=development
SECRET_KEY=troque-por-uma-chave-secreta-forte-aqui

# --- Banco de Dados ---
# SQLite para desenvolvimento (padrão)
DATABASE_URL=sqlite:///fitflow.db
# PostgreSQL para produção (descomente e ajuste):
# DATABASE_URL=postgresql://user:password@localhost:5432/fitflow_pro

# --- JWT ---
JWT_SECRET_KEY=troque-por-outra-chave-jwt-forte-aqui
# JWT_ACCESS_TOKEN_EXPIRES e JWT_REFRESH_TOKEN_EXPIRES são configurados no config.py

# --- CORS ---
# Origens permitidas separadas por vírgula
CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,http://localhost:3000

# --- Flask-Limiter ---
# Deixe vazio para usar memória (desenvolvimento)
# Em produção use Redis: redis://localhost:6379/0
RATELIMIT_STORAGE_URL=

# --- E-mail (Flask-Mail) ---
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=seu-email@gmail.com
MAIL_PASSWORD=sua-senha-de-app
MAIL_DEFAULT_SENDER=FitFlow Pro <noreply@fitflowpro.com.br>

# --- Asaas (Pagamentos) ---
ASAAS_API_KEY=
ASAAS_ENVIRONMENT=sandbox
# sandbox: https://sandbox.asaas.com/api/v3
# produção: https://api.asaas.com/v3

# --- Z-API (WhatsApp) ---
ZAPI_INSTANCE_ID=
ZAPI_TOKEN=
ZAPI_CLIENT_TOKEN=

# --- Anthropic (IA) ---
ANTHROPIC_API_KEY=

# --- Frontend ---
# URL base do Live Server em dev; domínio real em produção
FRONTEND_BASE_URL=http://127.0.0.1:6555
